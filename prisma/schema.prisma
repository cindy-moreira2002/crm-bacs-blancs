generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Lead {
  id              String   @id @default(cuid())
  firstName       String
  lastName        String
  email           String?
  phone           String?
  subject         String
  city            String?
  status          String   @default("nouveau")
  lastContactDate DateTime?
  notes           String?
  source          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
